<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Вход</title>
  <link rel="stylesheet" href="https://unpkg.com/@fontsource/geist-sans@5.2.5/index.css">
  <style>
    body {
      margin: 0;
      background: #070707;
      color: #fff;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      font-family: "Geist", "Geist Sans", system-ui, -apple-system, "Segoe UI", sans-serif;
      overflow: hidden;
    }
    body::before{
      content:"";
      position:fixed;
      inset:-120px;
      background:
        radial-gradient(700px 420px at 55% 45%, rgba(255,255,255,0.06), transparent 60%),
        radial-gradient(520px 320px at 35% 65%, rgba(255,255,255,0.04), transparent 60%),
        radial-gradient(520px 320px at 70% 70%, rgba(0,0,0,0.55), transparent 60%),
        linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.12));
      filter: blur(18px);
      opacity: 1;
      pointer-events:none;
    }
    .card {
      width: 360px;
      max-width: calc(100% - 48px);
      background: rgba(16,16,16,0.9);
      border: 1px solid rgba(255,255,255,0.10);
      border-radius: 12px;
      padding: 22px 22px 18px;
      box-shadow: 0 22px 70px rgba(0,0,0,0.85);
      backdrop-filter: blur(10px);
    }
    .title-row {
      display: flex;
      align-items: baseline;
      justify-content: center;
      gap: 10px;
      margin-bottom: 6px;
    }
    .title {
      font-size: 22px;
      font-weight: 700;
      margin: 0;
      letter-spacing: 0;
    }
    .title-x {
      font-size: 18px;
      font-weight: 500;
      opacity: 0.6;
      line-height: 1;
    }
    .subtitle {
      text-align: center;
      margin: 0 0 18px;
      font-size: 12.5px;
      color: rgba(255,255,255,0.55);
      font-weight: 400;
      letter-spacing: 0.01em;
    }
    .group { margin-bottom: 12px; }
    label {
      display: block;
      font-size: 11px;
      color: rgba(255,255,255,0.5);
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 600;
    }
    input {
      width: 100%;
      box-sizing: border-box;
      background: #1a1a1a;
      border: 1px solid rgba(255,255,255,0.14);
      padding: 10px 12px;
      border-radius: 8px;
      color: #fff;
      outline: none;
      font-size: 13px;
      font-family: inherit;
    }
    input::placeholder { color: rgba(255,255,255,0.35); }
    input:focus { border-color: rgba(255,255,255,0.30); }
    .error { color:#ff6b6b; font-size:12px; margin: 0 0 10px; text-align:center; }
    button {
      width: 100%;
      background: #e9e9e9;
      border: 1px solid #e9e9e9;
      color: #000;
      padding: 11px 12px;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 600;
      font-size: 13px;
      letter-spacing: 0.03em;
      margin-top: 10px;
      font-family: inherit;
    }
    button:hover { background: #ffffff; }
  </style>
</head>
<body>
  <div class="card">
    <div class="title-row">
      <h1 class="title">Majestic</h1>
      <div class="title-x">×</div>
      <h1 class="title">Curator</h1>
    </div>
    <p class="subtitle">Войдите с помощью логина и пароля</p>
    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <form method="post" action="/login">
      <div class="group">
        <label>Логин</label>
        <input name="username" autocomplete="username" placeholder="Логин" />
      </div>
      <div class="group">
        <label>Пароль</label>
        <input name="password" type="password" autocomplete="current-password" placeholder="Пароль" />
      </div>
      <button type="submit">Продолжить</button>
    </form>
  </div>
</body>
</html>

