<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Вход</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    body {
      margin: 0;
      background: #050505;
      color: #fff;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      font-family: "SF Pro Text", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    }
    .card {
      width: min(420px, 100%);
      background: #101010;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      padding: 22px;
      box-shadow: 0 18px 45px rgba(0,0,0,0.8);
    }
    .title-row {
      display: flex;
      align-items: baseline;
      justify-content: center;
      gap: 10px;
      margin-bottom: 6px;
    }
    .title {
      font-size: 20px;
      font-weight: 700;
      margin: 0;
      letter-spacing: 0;
    }
    .title-x {
      font-size: 18px;
      font-weight: 500;
      opacity: 0.6;
      line-height: 1;
    }
    .subtitle {
      text-align: center;
      margin: 0 0 22px;
      font-size: 12px;
      color: rgba(255,255,255,0.6);
      font-weight: 400;
      letter-spacing: 0.02em;
    }
    .group { margin-bottom: 12px; }
    label {
      display: block;
      font-size: 11px;
      color: rgba(255,255,255,0.6);
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 500;
    }
    input {
      width: 100%;
      box-sizing: border-box;
      background: #151515;
      border: 1px solid rgba(255,255,255,0.16);
      padding: 10px 12px;
      border-radius: 8px;
      color: #fff;
      outline: none;
      font-size: 13px;
      font-family: inherit;
    }
    input::placeholder { color: rgba(255,255,255,0.35); }
    input:focus { border-color: rgba(255,255,255,0.30); }
    .error { color:#ff6b6b; font-size:12px; margin: 0 0 10px; text-align:center; }
    button {
      width: 100%;
      background: #f3f3f3;
      border: 1px solid #f3f3f3;
      color: #000;
      padding: 10px 12px;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 500;
      font-size: 13px;
      letter-spacing: 0.03em;
      margin-top: 8px;
      font-family: inherit;
    }
    button:hover { background: #ffffff; }
  </style>
</head>
<body>
  <div class="card">
    <div class="title-row">
      <h1 class="title">Majestic</h1>
      <div class="title-x">×</div>
      <h1 class="title">Curator</h1>
    </div>
    <p class="subtitle">Войдите с помощью логина и пароля</p>
    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <form method="post" action="/login">
      <div class="group">
        <label>Логин</label>
        <input name="username" autocomplete="username" placeholder="Логин" />
      </div>
      <div class="group">
        <label>Пароль</label>
        <input name="password" type="password" autocomplete="current-password" placeholder="Пароль" />
      </div>
      <button type="submit">Продолжить</button>
    </form>
  </div>
</body>
</html>

