<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Boston RP Admin</title>
    <link rel="stylesheet" href="/style.css">
    <!-- Тема: размытый фон, одна плита app-body (шапка+сайдбар+контент). Уберите link — останется только style.css -->
    <link rel="stylesheet" href="/theme-app.css">
</head>
<body>

    <div class="app-shell">
        <div class="app-body">
            <header class="app-topbar" aria-label="Панель страницы">
                <div class="header-left">
                    <a href="/" class="topbar-logo" title="Главная" aria-label="Раздел: Главная">
                        <span class="topbar-logo-mark" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                                <rect width="20" height="14" x="2" y="3" rx="2"></rect>
                                <line x1="8" x2="16" y1="21" y2="21"></line>
                                <line x1="12" x2="12" y1="17" y2="21"></line>
                            </svg>
                        </span>
                    </a>
                    <div class="header-separator"></div>
                    <span class="page-title" id="current-title">Главная</span>
                </div>
                <div class="header-actions" id="header-actions" style="display: none;">
                    <button type="button" class="btn-month" id="btn-add-family" onclick="openModal()">
                        <span class="btn-month-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v8"></path><path d="M8 12h8"></path></svg>
                        </span>
                        <span>Добавить семью</span>
                    </button>
                </div>
            </header>

            <div class="app-workspace-split">
                <div class="sidebar-container">
                    <%- include('partials/sidebar', { user }) %>
                </div>

                <main class="main-content">
                    <div class="content-body" id="page-content">
                    </div>
                </main>
            </div>
        </div>
    </div>

    <%- include('partials/modals') %>

    <div id="toast-root"></div>


    <script>
        window.__BOOTSTRAP__ = {
            currentUser: <%- JSON.stringify(user || null) %>,
            initialPage: <%- JSON.stringify(typeof activePage === 'string' ? activePage : 'Главная') %>,
            eventDetailPath: <%- JSON.stringify(typeof eventDetailPath === 'string' ? eventDetailPath : null) %>
        };
    </script>
    <script src="/app/00-core.js"></script>
    <script src="/app/10-api.js"></script>
    <script src="/app/25-dashboard.js"></script>
    <script src="/app/20-users.js"></script>
    <script src="/app/30-families.js"></script>
    <script src="/app/35-curators.js"></script>
    <script src="/app/40-nicknames-events.js"></script>
    <script src="/app/45-events.js"></script>
    <script src="/app/50-leaders.js"></script>
    <script src="/app/60-materials.js"></script>
    <script src="/app/70-settings.js"></script>
    <script src="/app/90-navigation.js"></script>
</body>
</html>