    <main class="main-content">
        <header class="content-header">
            <div class="header-left">
                <button class="sidebar-trigger">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"></rect><path d="M9 3v18"></path></svg>
                </button>
                <div class="header-separator"></div>
                <span class="page-title" id="current-title">Панель управления</span>
            </div>
            <div class="header-actions" id="header-actions" style="display: none;">
                <button type="button" class="btn-pill" id="btn-add-family" onclick="openModal()">Добавить семью</button>
            </div>
        </header>

        <div class="content-body" id="page-content">
            </div>
    </main>

    <div id="modal-overlay" class="modal-overlay">
        <div class="modal-card">
            <h2 id="modal-title" style="margin-top:0; font-size:18px;">Добавить семью</h2>
            <form id="family-form">
                <input type="hidden" id="edit-index">
                <div class="form-group">
                    <label>Название семьи *</label>
                    <input type="text" id="fam-name" required>
                </div>
                <div class="form-group">
                    <label>ID Семьи *</label>
                    <input type="text" id="fam-id" required>
                </div>
                <div class="form-group">
                    <label>Лидер (Ник)</label>
                    <input type="text" id="fam-leader">
                </div>
                <div class="form-group">
                    <label>Discord ID</label>
                    <input type="text" id="fam-discord">
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn-ghost" onclick="closeModal()">Отмена</button>
                    <button type="submit" class="btn-primary">Сохранить</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        let families = [{ name: "Marabunta", id: "101", leader: "Dmitry Black", discord: "293847561023" }];
        
        const pageContent = document.getElementById('page-content');
        const pageTitle = document.getElementById('current-title');
        const headerActions = document.getElementById('header-actions');

        function renderFamilies() {
            pageContent.innerHTML = `
                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Семья</th>
                                <th>ID</th>
                                <th>Лидер</th>
                                <th>Discord ID</th>
                                <th style="text-align:right">Действие</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${families.map((f, i) => `
                                <tr>
                                    <td>${f.name}</td>
                                    <td><span class="id-tag">#${f.id}</span></td>
                                    <td>${f.leader || '—'}</td>
                                    <td>${f.discord || '—'}</td>
                                    <td style="text-align:right">
                                        <button class="btn-edit" onclick="editFamily(${i})">Изменить</button>
                                        <button class="btn-edit btn-delete" onclick="deleteFamily(${i})">Удалить</button>
                                    </td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>`;
        }

        document.querySelectorAll('.nav-item').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                document.querySelectorAll('.nav-item').forEach(x => x.classList.remove('active'));
                btn.classList.add('active');
                const title = btn.getAttribute('data-title');
                pageTitle.textContent = title;
                if (title === 'Семьи') {
                    headerActions.style.display = 'flex';
                    renderFamilies();
                } else {
                    headerActions.style.display = 'none';
                    pageContent.innerHTML = `<p style="color:#444">Раздел "${title}" находится в разработке.</p>`;
                }
            });
        });

        function openModal() {
            document.getElementById('family-form').reset();
            document.getElementById('edit-index').value = "";
            document.getElementById('modal-title').textContent = "Добавить семью";
            document.getElementById('modal-overlay').style.display = 'flex';
        }

        function closeModal() { document.getElementById('modal-overlay').style.display = 'none'; }
        
        function editFamily(i) {
            const f = families[i];
            document.getElementById('fam-name').value = f.name;
            document.getElementById('fam-id').value = f.id;
            document.getElementById('fam-leader').value = f.leader;
            document.getElementById('fam-discord').value = f.discord;
            document.getElementById('edit-index').value = i;
            document.getElementById('modal-title').textContent = "Редактировать семью";
            document.getElementById('modal-overlay').style.display = 'flex';
        }

        function deleteFamily(i) {
            if (confirm('Удалить эту семью?')) {
                families.splice(i, 1);
                renderFamilies();
            }
        }

        document.getElementById('family-form').onsubmit = (e) => {
            e.preventDefault();
            const i = document.getElementById('edit-index').value;
            const data = {
                name: document.getElementById('fam-name').value,
                id: document.getElementById('fam-id').value,
                leader: document.getElementById('fam-leader').value,
                discord: document.getElementById('fam-discord').value
            };
            if(i === "") families.push(data); else families[i] = data;
            closeModal();
            renderFamilies();
        };

        // Начальная загрузка
        pageContent.innerHTML = `<p style="color:#444">Выберите раздел в меню слева.</p>`;
    </script>
</body>
</html>