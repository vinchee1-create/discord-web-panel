<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Boston RP Admin</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>

    <div class="sidebar-container">
        <aside class="sidebar-inner">
            <div class="sidebar-header">
                <a href="/" class="brand-button">
                    <div class="brand-icon-box">
                        <svg viewBox="0 0 18 18" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M15.2222 10.6018C15.7975 10.9575 16.3909 11.2823 17 11.5751V10.6472C15.4289 9.82681 12.1169 7.74904 9.88889 3.89655C9.88889 3.89655 9.88889 3 9 3C8.11111 3 8.11111 3.89655 8.11111 3.89655C5.88311 7.74904 2.57111 9.82681 1 10.6472V11.5751C1.6091 11.2823 2.20252 10.9575 2.77778 10.6018V11.9655H1V13.7586H8.11111V16H9.88889V13.7586H17V11.9655H15.2222V10.6018ZM14.3333 11.9655H12.5556V8.63257C13.1213 9.12904 13.7149 9.59225 14.3333 10.02V11.9655ZM3.66667 10.0195C4.28514 9.59202 4.87872 9.1289 5.44444 8.63257V11.9655H3.66667V10.0195ZM6.33333 11.9655V7.80016C6.98009 7.15343 7.57458 6.45563 8.11111 5.71342V11.9655H6.33333ZM9.88889 5.71386C10.4256 6.45598 11.02 7.15377 11.6667 7.80057V11.9655H9.88889V5.71386Z"></path></svg>
                    </div>
                    <div class="brand-text-container">
                        <span class="brand-main-text">Boston</span>
                        <span class="brand-sub-text">Crime Bot</span>
                    </div>
                </a>
            </div>

            <div class="sidebar-content">
                <nav class="nav-list" id="sidebar-nav">
                    <a href="#" class="nav-item active" data-title="Панель управления"><span>Главная</span></a>
                    <a href="#" class="nav-item" data-title="Мероприятия"><span>Мероприятия</span></a>
                    <a href="#" class="nav-item" data-title="Кураторы"><span>Кураторы</span></a>
                    <a href="#" class="nav-item" data-title="Активность"><span>Активность</span></a>
                    <a href="#" class="nav-item" data-title="Семьи"><span>Семьи</span></a>
                    <a href="#" class="nav-item" data-title="Лидеры"><span>Лидеры</span></a>
                    <a href="#" class="nav-item" data-title="Онлайн Л/Ф"><span>Онлайн Л/Ф</span></a>
                    <a href="#" class="nav-item" data-title="Собрания"><span>Собрания</span></a>
                    <a href="#" class="nav-item" data-title="Никнеймы"><span>Никнеймы</span></a>
                    <a href="#" class="nav-item" data-title="Настройки"><span>Настройки</span></a>
                </nav>
            </div>
        </aside>
    </div>

    <main class="main-content">
        <header class="content-header">
            <div class="header-left">
                <button class="sidebar-trigger"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"></rect><path d="M9 3v18"></path></svg></button>
                <div class="header-separator"></div>
                <span class="page-title" id="current-title">Панель управления</span>
            </div>
        </header>

        <div class="content-body" id="page-content">
            </div>
    </main>

    <div id="modal-overlay" class="modal-overlay">
        <div class="modal-card">
            <h2 id="modal-title">Добавить семью</h2>
            <form id="family-form">
                <input type="hidden" id="edit-index">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Семья *</label>
                        <input type="text" id="fam-name" required placeholder="Название">
                    </div>
                    <div class="form-group">
                        <label>ID *</label>
                        <input type="text" id="fam-id" required placeholder="ID">
                    </div>
                    <div class="form-group">
                        <label>Лидер</label>
                        <input type="text" id="fam-leader" placeholder="Никнейм">
                    </div>
                    <div class="form-group">
                        <label>Discord ID</label>
                        <input type="text" id="fam-discord" placeholder="ID">
                    </div>
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn-ghost" onclick="closeModal()">Отмена</button>
                    <button type="submit" class="btn-primary">Сохранить</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // Имитация базы данных
        let families = [
            { name: "Marabunta", id: "101", leader: "Dmitry Black", discord: "293847561023" }
        ];

        const pageContent = document.getElementById('page-content');
        const pageTitle = document.getElementById('current-title');
        const modal = document.getElementById('modal-overlay');

        // Рендеринг таблицы семей
        function showFamilies() {
            pageContent.innerHTML = `
                <div class="page-header-actions">
                    <button class="btn-primary" onclick="openModal()">Добавить семью</button>
                </div>
                <div class="data-wrapper">
                    <table class="main-table">
                        <thead>
                            <tr>
                                <th>Семья</th>
                                <th>ID</th>
                                <th>Лидер</th>
                                <th>Discord ID</th>
                                <th style="text-align:right">Действие</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${families.map((f, index) => `
                                <tr>
                                    <td class="font-medium">${f.name}</td>
                                    <td><span class="id-badge">#${f.id}</span></td>
                                    <td>${f.leader || '<span class="empty">—</span>'}</td>
                                    <td>${f.discord || '<span class="empty">—</span>'}</td>
                                    <td style="text-align:right">
                                        <button class="btn-edit" onclick="editFamily(${index})">Изменить</button>
                                    </td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
            `;
        }

        // Переключение вкладок
        document.querySelectorAll('.nav-item').forEach(item => {
            item.addEventListener('click', (e) => {
                e.preventDefault();
                document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
                item.classList.add('active');
                const title = item.getAttribute('data-title');
                pageTitle.textContent = title;

                if (title === 'Семьи') {
                    showFamilies();
                } else {
                    pageContent.innerHTML = `<div class="empty-state">Раздел "${title}" в разработке</div>`;
                }
            });
        });

        // Работа с модальным окном
        function openModal() {
            document.getElementById('family-form').reset();
            document.getElementById('edit-index').value = "";
            document.getElementById('modal-title').textContent = "Добавить семью";
            modal.style.display = 'flex';
        }

        function closeModal() { modal.style.display = 'none'; }

        function editFamily(index) {
            const f = families[index];
            document.getElementById('fam-name').value = f.name;
            document.getElementById('fam-id').value = f.id;
            document.getElementById('fam-leader').value = f.leader;
            document.getElementById('fam-discord').value = f.discord;
            document.getElementById('edit-index').value = index;
            document.getElementById('modal-title').textContent = "Редактировать семью";
            modal.style.display = 'flex';
        }

        document.getElementById('family-form').onsubmit = (e) => {
            e.preventDefault();
            const index = document.getElementById('edit-index').value;
            const newFam = {
                name: document.getElementById('fam-name').value,
                id: document.getElementById('fam-id').value,
                leader: document.getElementById('fam-leader').value,
                discord: document.getElementById('fam-discord').value
            };

            if (index === "") families.push(newFam);
            else families[index] = newFam;

            closeModal();
            showFamilies();
        };
    </script>
</body>
</html>