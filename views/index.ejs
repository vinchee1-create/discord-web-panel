<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Boston RP Admin</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>

    <div class="sidebar-container">
        <aside class="sidebar-inner">
            <div class="sidebar-header">
                <a href="/" class="brand-wrapper">
                    <div class="brand-logo">
                        <svg viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15.2222 10.6018C15.7975 10.9575 16.3909 11.2823 17 11.5751V10.6472C15.4289 9.82681 12.1169 7.74904 9.88889 3.89655C9.88889 3.89655 9.88889 3 9 3C8.11111 3 8.11111 3.89655 8.11111 3.89655C5.88311 7.74904 2.57111 9.82681 1 10.6472V11.5751C1.6091 11.2823 2.20252 10.9575 2.77778 10.6018V11.9655H1V13.7586H8.11111V16H9.88889V13.7586H17V11.9655H15.2222V10.6018ZM14.3333 11.9655H12.5556V8.63257C13.1213 9.12904 13.7149 9.59225 14.3333 10.02V11.9655ZM3.66667 10.0195C4.28514 9.59202 4.87872 9.1289 5.44444 8.63257V11.9655H3.66667V10.0195ZM6.33333 11.9655V7.80016C6.98009 7.15343 7.57458 6.45563 8.11111 5.71342V11.9655H6.33333ZM9.88889 5.71386C10.4256 6.45598 11.02 7.15377 11.6667 7.80057V11.9655H9.88889V5.71386Z" fill="white"></path></svg>
                    </div>
                    <div class="brand-info">
                        <span class="brand-name">Boston</span>
                        <span class="brand-status"><%= data.memberCount %> онлайн</span>
                    </div>
                </a>
            </div>

            <div class="sidebar-content">
                <nav class="nav-list" id="sidebar-nav">
                    <a href="#" class="nav-item active" data-title="Панель управления">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"></rect><line x1="8" x2="16" y1="21" y2="21"></line><line x1="12" x2="12" y1="17" y2="21"></line></svg>
                        <span>Главная</span>
                    </a>
                    <a href="#" class="nav-item" data-title="Управление отпусками">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 8c0-2.76-2.46-5-5.5-5S2 5.24 2 8h2l1-1 1 1h4"></path><path d="M13 7.14A5.82 5.82 0 0 1 16.5 6c3.04 0 5.5 2.24 5.5 5h-3l-1-1-1 1h-3"></path><path d="M5.89 9.71c-2.15 2.15-2.3 5.47-.35 7.43l4.24-4.25.7-.7.71-.71 2.12-2.12c-1.95-1.96-5.27-1.8-7.42.35"></path><path d="M11 15.5c.5 2.5-.17 4.5-1 6.5h4c2-5.5-.5-12-1-14"></path></svg>
                        <span>Отпуска</span>
                    </a>
                </nav>
            </div>
        </aside>
    </div>

    <main class="main-content">
        <header class="content-header">
            <div class="header-left">
                <button class="sidebar-trigger">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"></rect><path d="M9 3v18"></path></svg>
                </button>
                <div class="header-separator"></div>
                <span class="page-title" id="current-page-title">Панель управления</span>
            </div>
        </header>

        <div class="content-body" id="page-content">
            <h1>Добро пожаловать</h1>
            <p>Выберите раздел в меню слева.</p>
        </div>
    </main>

    <script>
        const navItems = document.querySelectorAll('.nav-item');
        const pageTitle = document.getElementById('current-page-title');

        navItems.forEach(item => {
            item.addEventListener('click', (e) => {
                e.preventDefault();
                
                // Убираем активный класс у всех и добавляем нажатому
                navItems.forEach(nav => nav.classList.remove('active'));
                item.classList.add('active');

                // Меняем текст в шапке
                const newTitle = item.getAttribute('data-title');
                pageTitle.textContent = newTitle;
            });
        });
    </script>
</body>
</html>