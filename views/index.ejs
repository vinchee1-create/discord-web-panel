<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Boston Admin Panel</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="sidebar-container">
        <aside class="sidebar-inner">
            <div class="sidebar-header">
                <a href="/" class="brand-card">
                    <div class="brand-logo">
                        <svg viewBox="0 0 18 18" fill="white" xmlns="http://www.w3.org/2000/svg">
                            <path d="M15.2222 10.6018C15.7975 10.9575 16.3909 11.2823 17 11.5751V10.6472C15.4289 9.82681 12.1169 7.74904 9.88889 3.89655C9.88889 3.89655 9.88889 3 9 3C8.11111 3 8.11111 3.89655 8.11111 3.89655C5.88311 7.74904 2.57111 9.82681 1 10.6472V11.5751C1.6091 11.2823 2.20252 10.9575 2.77778 10.6018V11.9655H1V13.7586H8.11111V16H9.88889V13.7586H17V11.9655H15.2222V10.6018ZM14.3333 11.9655H12.5556V8.63257C13.1213 9.12904 13.7149 9.59225 14.3333 10.02V11.9655ZM3.66667 10.0195C4.28514 9.59202 4.87872 9.1289 5.44444 8.63257V11.9655H3.66667V10.0195ZM6.33333 11.9655V7.80016C6.98009 7.15343 7.57458 6.45563 8.11111 5.71342V11.9655H6.33333ZM9.88889 5.71386C10.4256 6.45598 11.02 7.15377 11.6667 7.80057V11.9655H9.88889V5.71386Z" />
                        </svg>
                    </div>
                    <div class="brand-details">
                        <span class="brand-name">Boston</span>
                        <span class="brand-online"><%= data.memberCount %> онлайн</span>
                    </div>
                </a>
            </div>

            <div class="sidebar-content">
                <nav class="nav-menu">
                    <a href="/" class="nav-link">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"></rect><line x1="8" x2="16" y1="21" y2="21"></line><line x1="12" x2="12" y1="17" y2="21"></line></svg>
                        <span>Главная</span>
                    </a>
                    <a href="/logs/fractions-money" class="nav-link active">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5h1"></path><path d="M3 12h1"></path><path d="M3 19h1"></path><path d="M8 5h1"></path><path d="M8 12h1"></path><path d="M8 19h1"></path><path d="M13 5h8"></path><path d="M13 12h8"></path><path d="M13 19h8"></path></svg>
                        <span>Деньги фракций</span>
                    </a>
                </nav>
            </div>
        </aside>
    </div>

    <main class="main-wrapper">
        <header class="main-header">
            <div class="header-breadcrumb">
                <button class="icon-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"></rect><path d="M9 3v18"></path></svg>
                </button>
                <div class="sep"></div>
                <span class="current-path">Логи > Деньги фракций</span>
            </div>
        </header>
        <div class="page-content">
            </div>
    </main>

</body>
</html>