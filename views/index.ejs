<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Boston RP Admin</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>

    <div class="sidebar-container">
        <aside class="sidebar-inner">
            
            <div class="sidebar-header">
                <a href="/" class="brand-wrapper">
                    <div class="brand-logo">
                        <svg viewBox="0 0 18 18" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                            <path d="M15.2222 10.6018C15.7975 10.9575 16.3909 11.2823 17 11.5751V10.6472C15.4289 9.82681 12.1169 7.74904 9.88889 3.89655C9.88889 3.89655 9.88889 3 9 3C8.11111 3 8.11111 3.89655 8.11111 3.89655C5.88311 7.74904 2.57111 9.82681 1 10.6472V11.5751C1.6091 11.2823 2.20252 10.9575 2.77778 10.6018V11.9655H1V13.7586H8.11111V16H9.88889V13.7586H17V11.9655H15.2222V10.6018ZM14.3333 11.9655H12.5556V8.63257C13.1213 9.12904 13.7149 9.59225 14.3333 10.02V11.9655ZM3.66667 10.0195C4.28514 9.59202 4.87872 9.1289 5.44444 8.63257V11.9655H3.66667V10.0195ZM6.33333 11.9655V7.80016C6.98009 7.15343 7.57458 6.45563 8.11111 5.71342V11.9655H6.33333ZM9.88889 5.71386C10.4256 6.45598 11.02 7.15377 11.6667 7.80057V11.9655H9.88889V5.71386Z"></path>
                        </svg>
                    </div>
                    <div class="brand-text">
                        <span class="brand-name">Boston</span>
                        <span class="brand-status"><%= data.memberCount %> онлайн</span>
                    </div>
                </a>
            </div>

            <div class="search-container">
                <button class="search-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
                    <span>Поиск...</span>
                    <span class="search-shortcut">Ctrl+K</span>
                </button>
            </div>

            <div class="sidebar-content">
                <div class="group-label">Основное</div>
                <nav>
                    <a href="/" class="nav-item active">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="20" height="14" x="2" y="3" rx="2"></rect>
                            <line x1="8" x2="16" y1="21" y2="21"></line>
                            <line x1="12" x2="12" y1="17" y2="21"></line>
                        </svg>
                        <span class="flex-1">Главная</span>
                        <button class="star-btn">
                            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
                        </button>
                    </a>
                    <a href="/absences" class="nav-item">
                        <span class="nav-icon" style="text-align: center; display: inline-block;">🌴</span>
                        <span>Отпуска</span>
                    </a>
                </nav>

                <div class="group-label">Администрирование</div>
                <nav>
                    <a href="#" class="nav-item">🛡️ Модерация</a>
                    <a href="#" class="nav-item">📊 Экономика</a>
                </nav>
            </div>

            <div class="sidebar-footer">
                <div class="profile-card">
                    <div class="profile-avatar">D</div>
                    <div class="brand-text">
                        <span class="brand-name" style="font-size: 13px;">davinchee</span>
                        <span class="brand-status">6 level</span>
                    </div>
                    <span style="margin-left: auto; opacity: 0.3; font-size: 10px;">↕️</span>
                </div>
            </div>
        </aside>
    </div>

    <main class="main-content">
        <h1>Связь установлена</h1>
        
        <div class="status-card">
            <div class="status-line">
                <span class="status-label">Статус бота:</span> 
                <span class="status-value highlight-green">В сети</span>
            </div>
            <div class="status-line">
                <span class="status-label">Сервер:</span> 
                <span class="status-value">Boston RP</span>
            </div>
            <div class="status-line">
                <span class="status-label">Людей на сервере:</span> 
                <span class="status-value"><%= data.memberCount %></span>
            </div>
        </div>
    </main>

</body>
</html>