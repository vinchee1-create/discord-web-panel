            </div>
        </aside>
    </div>

    <main class="main-content">
        <header class="content-header">
            <div class="header-left">
                <button class="sidebar-trigger">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"></rect><path d="M9 3v18"></path></svg>
                </button>
                <div class="header-separator"></div>
                <span class="page-title" id="current-title">Панель управления</span>
            </div>
        </header>

        <div class="content-body" id="page-content">
            <div class="welcome-section">
                <h1>Crime Bot Dashboard</h1>
                <p>Выберите нужный раздел в меню слева для управления сервером.</p>
            </div>
        </div>
    </main>

    <script>
        const navItems = document.querySelectorAll('.nav-item');
        const pageTitle = document.getElementById('current-title');

        navItems.forEach(item => {
            item.addEventListener('click', (e) => {
                e.preventDefault();
                navItems.forEach(i => i.classList.remove('active'));
                item.classList.add('active');
                
                // Динамическая смена заголовка
                pageTitle.textContent = item.getAttribute('data-title');
            });
        });
    </script>
</body>
</html>