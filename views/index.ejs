<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Boston Admin Panel</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="wrapper">
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="logo-box"></div>
                <div class="header-text">
                    <span class="server-title">Boston</span>
                    <span class="online-status"><%= data.memberCount %> онлайн</span>
                </div>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-group">
                    <a href="#" class="nav-item active">🏠 Главная</a>
                    <a href="#" class="nav-item">🌴 Отпуска</a>
                </div>

                <div class="nav-group">
                    <span class="group-label">Администрирование</span>
                    <a href="#" class="nav-item">🛡️ Модерация</a>
                    <a href="#" class="nav-item">📊 Экономика</a>
                    <a href="#" class="nav-item">📈 Аналитика</a>
                </div>
            </nav>
        </aside>

        <main class="main-content">
            <header class="content-header">
                <div class="header-left">
                    <h1>Главная</h1>
                </div>
                <div class="header-right">
                    <span class="bot-indicator">Бот: <%= data.botStatus %></span>
                </div>
            </header>
            
            <div class="content-body">
                </div>
        </main>
    </div>
</body>
</html>