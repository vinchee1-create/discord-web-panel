<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Boston Admin Panel</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div data-slot="sidebar-wrapper" class="group/sidebar-wrapper flex min-h-svh w-full" style="--sidebar-width: 16rem; --sidebar-width-icon: 3rem;">
    <div class="group peer text-sidebar-foreground hidden md:block" data-state="expanded" data-variant="inset" data-side="left" data-slot="sidebar">
        <div data-slot="sidebar-container" class="fixed inset-y-0 z-10 hidden h-svh w-(--sidebar-width) transition-[left,right,width] duration-200 ease-linear md:flex left-0 p-2">
            <div data-sidebar="sidebar" data-slot="sidebar-inner" class="bg-sidebar flex h-full w-full flex-col rounded-lg border border-sidebar-border shadow-sm">
                
                <div data-slot="sidebar-header" class="flex flex-col gap-2 p-2">
                    <ul data-slot="sidebar-menu" class="flex w-full min-w-0 flex-col gap-1">
                        <li class="group/menu-item relative">
                            <a data-slot="sidebar-menu-button" data-size="lg" class="peer/menu-button flex w-full items-center gap-2 overflow-hidden rounded-md p-2 text-left hover:bg-sidebar-accent h-12" href="/">
                                <div class="text-sidebar-primary-foreground flex aspect-square size-8 items-center justify-center rounded-lg bg-[#45cd5b]">
                                    <svg viewBox="0 0 18 18" fill="currentColor" class="size-4 text-white">
                                        <path d="M15.2222 10.6018C15.7975 10.9575 16.3909 11.2823 17 11.5751V10.6472C15.4289 9.82681 12.1169 7.74904 9.88889 3.89655C9.88889 3.89655 9.88889 3 9 3C8.11111 3 8.11111 3.89655 8.11111 3.89655C5.88311 7.74904 2.57111 9.82681 1 10.6472V11.5751C1.6091 11.2823 2.20252 10.9575 2.77778 10.6018V11.9655H1V13.7586H8.11111V16H9.88889V13.7586H17V11.9655H15.2222V10.6018ZM14.3333 11.9655H12.5556V8.63257C13.1213 9.12904 13.7149 9.59225 14.3333 10.02V11.9655ZM3.66667 10.0195C4.28514 9.59202 4.87872 9.1289 5.44444 8.63257V11.9655H3.66667V10.0195ZM6.33333 11.9655V7.80016C6.98009 7.15343 7.57458 6.45563 8.11111 5.71342V11.9655H6.33333ZM9.88889 5.71386C10.4256 6.45598 11.02 7.15377 11.6667 7.80057V11.9655H9.88889V5.71386Z"></path>
                                    </svg>
                                </div>
                                <div class="flex flex-col gap-0.5 leading-none">
                                    <span class="font-semibold text-sm text-white">Boston</span>
                                    <span class="text-[11px] text-[#45cd5b] font-medium"><%= data.memberCount %> онлайн</span>
                                </div>
                            </a>
                        </li>
                    </ul>
                </div>

                <div data-slot="sidebar-content" class="flex min-h-0 flex-1 flex-col overflow-auto gap-1 py-2 px-2">
                    <ul data-slot="sidebar-menu" class="flex w-full min-w-0 flex-col gap-1">
                        <li class="group/menu-item relative">
                            <a class="flex w-full items-center gap-2 rounded-md p-2 text-sm transition-colors hover:bg-sidebar-accent text-sidebar-foreground h-8" href="/">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70"><rect width="20" height="14" x="2" y="3" rx="2"></rect><line x1="8" x2="16" y1="21" y2="21"></line><line x1="12" x2="12" y1="17" y2="21"></line></svg>
                                <span>Главная</span>
                            </a>
                        </li>
                        <li class="group/menu-item relative">
                            <a class="flex w-full items-center gap-2 rounded-md p-2 text-sm transition-colors bg-sidebar-accent text-sidebar-accent-foreground h-8" href="/logs/fractions-money">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5h1"></path><path d="M3 12h1"></path><path d="M3 19h1"></path><path d="M8 5h1"></path><path d="M8 12h1"></path><path d="M8 19h1"></path><path d="M13 5h8"></path><path d="M13 12h8"></path><path d="M13 19h8"></path></svg>
                                <span>Деньги фракций</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <main class="flex-1 flex flex-col bg-sidebar min-w-0">
        <header class="flex h-12 shrink-0 items-center gap-2 border-b border-sidebar-border px-4">
            <div class="flex items-center gap-2 text-sm">
                <button class="icon-btn opacity-50 hover:opacity-100 transition-opacity">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"></rect><path d="M9 3v18"></path></svg>
                </button>
                <div class="h-4 w-px bg-sidebar-border mx-1"></div>
                <span class="text-white opacity-90">Деньги фракций</span>
            </div>
        </header>
        
        <div class="flex flex-1 flex-col gap-4 p-4 overflow-auto">
            <h1 class="text-2xl font-semibold">Связь установлена</h1>
        </div>
    </main>
</div>

</body>
</html>