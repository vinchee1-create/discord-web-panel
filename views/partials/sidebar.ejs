<aside class="sidebar">
    <a href="/" class="sidebar-brand" title="На главную" aria-label="Boston Crime — главная">
        <span class="logo" aria-hidden="true">B</span>
        <span class="sidebar-brand-text">Boston Crime</span>
    </a>
    <div class="sidebar-nav-scroll">
        <div class="nav-block">
            <h3>Основное</h3>
            <nav>
                <a href="/" class="nav-item active" data-title="Главная">Главная</a>
                <a href="/tasks" class="nav-item" data-title="Задачи">
                    Задачи
                    <span class="nav-badge" id="nav-badge-tasks" style="display:none">0</span>
                </a>
                <a href="/obzvon" class="nav-item" data-title="Обзвон">Обзвон</a>
                <a href="/events" class="nav-item" data-title="Мероприятия">Мероприятия</a>
                <a href="/curators" class="nav-item" data-title="Кураторы">Кураторы</a>
                <a href="/activity" class="nav-item" data-title="Активность">Активность</a>
            </nav>
        </div>

        <div class="nav-block">
            <h3>Информация</h3>
            <nav>
                <a href="/families" class="nav-item" data-title="Семьи">Семьи</a>
                <a href="/leaders" class="nav-item" data-title="Лидеры">Лидеры</a>
                <a href="/family-materials" class="nav-item" data-title="Материалы семей">
                    Материалы семей
                    <span class="nav-badge" id="nav-badge-family-materials" style="display:none">0</span>
                </a>
                <a href="/faction-materials" class="nav-item" data-title="Материалы фракций">
                    Материалы фракций
                    <span class="nav-badge" id="nav-badge-faction-materials" style="display:none">0</span>
                </a>
                <a href="/capture-map" class="nav-item" data-title="Карта каптов">Карта каптов</a>
            </nav>
        </div>

        <div class="nav-block">
            <h3>Статистика</h3>
            <nav>
                <a href="/online" class="nav-item" data-title="Онлайн Л/Ф">Онлайн Л/Ф</a>
                <a href="/moderation" class="nav-item" data-title="Модерация">Модерация</a>
            </nav>
        </div>

        <% if (user && user.role_level >= 4) { %>
        <div class="nav-block">
            <h3>Настройки</h3>
            <nav>
                <a href="/users" class="nav-item" data-title="Пользователи">Пользователи</a>
                <a href="/settings" class="nav-item" data-title="Настройки">Настройки</a>
            </nav>
        </div>
        <% } %>
    </div>

    <div class="sidebar-footer">
        <div class="profile-menu" id="profile-menu">
            <form method="post" action="/logout" style="margin:0;">
                <button type="submit" class="profile-menu-item">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" x2="9" y1="12" y2="12"></line></svg>
                    Выход
                </button>
            </form>
        </div>
        <button type="button" class="profile-button" id="profile-button">
            <div class="profile-avatar"><%= (user?.username || '?').slice(0,1).toUpperCase() %></div>
            <div class="profile-meta">
                <div class="profile-name"><%= user?.username || '' %></div>
                <div class="profile-lvl"><%= user?.role_level || 0 %> level</div>
            </div>
            <div class="profile-chevron">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </div>
        </button>
    </div>
</aside>
